# Card Platform — Environment Variables
# Copy to .env and populate with your local values

# Auth mode: 'dev' for local JWT, 'production' for AAD-B2C MSAL
AUTH_MODE=dev

# Test mode: enables test-only endpoints (POST /api/v1/test/*)
TEST_MODE=false

# JWT secret for AUTH_MODE=dev (any random string)
JWT_SECRET=change-me-in-production

# PostgreSQL connection
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/card_platform?schema=public

# Redis connection
REDIS_URL=redis://localhost:6379

# API service
API_PORT=3001
API_HOST=http://localhost:3001

# Socket service
SOCKET_PORT=3002
SOCKET_HOST=http://localhost:3002
# Allowed CORS origin for socket-service (comma-separated or * for dev)
CORS_ORIGIN=http://localhost:5173

# Worker service
WORKER_PORT=3003

# Frontend (Vite dev server)
VITE_API_URL=http://localhost:3001/api/v1
VITE_SOCKET_URL=http://localhost:3002
# Auth mode for the frontend: 'dev' for local JWT issuer, 'production' for AAD-B2C MSAL
VITE_AUTH_MODE=production

# Azure AD B2C (production only — leave empty for dev).
# The MSAL redirect URI is derived from window.location.origin at runtime,
# so there is no VITE_B2C_REDIRECT_URI env var. Every host the app is
# served from (custom domain, Container App default hostname, localhost)
# must be registered in the B2C app as both a Redirect URI and a
# Post-logout Redirect URI.
VITE_B2C_CLIENT_ID=096195ca-be77-44f5-9a5b-40e154f2ca46
VITE_B2C_AUTHORITY=https://cards.b2clogin.com/cards.onmicrosoft.com/B2C_1_SUSI
VITE_B2C_KNOWN_AUTHORITIES=cards.b2clogin.com

# VAPID keys for Web Push (generated by scripts/generate-vapid.sh)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@platform.example.com

# Logging
LOG_LEVEL=debug
# Frontend log level (debug | info | warn | error). Controls what the logger utility prints.
VITE_LOG_LEVEL=info
