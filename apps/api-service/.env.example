# API Service Environment Variables

# Database connection string for PostgreSQL 16
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/card_platform?schema=public

# Redis connection URL for presence, caching, and pub/sub
# Default: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# JWT secret for HS256 token signing in AUTH_MODE=dev
# NEVER commit a real secret — use a secrets manager in production
JWT_SECRET=your-dev-jwt-secret-here

# Auth mode: "dev" uses local HS256 JWT; "production" uses Azure AD B2C JWKS
AUTH_MODE=dev

# API port
API_PORT=3001

# Log level (error, warn, info, debug)
LOG_LEVEL=info

# Test mode — enables test-only routes (POST /api/v1/test/reset etc.)
# Set to "true" only in CI/test environments. NEVER in production.
TEST_MODE=false
