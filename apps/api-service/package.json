{
  "name": "@card-platform/api-service",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -b",
    "dev": "ts-node-dev --respawn src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests --runInBand",
    "lint": "echo \"No linter configured yet\" && exit 0"
  },
  "dependencies": {
    "@card-platform/shared-types": "*",
    "@prisma/client": "^5.14.0",
    "bullmq": "^5.7.0",
    "cors": "^2.8.5",
    "express": "^4.19.0",
    "ioredis": "^5.4.0",
    "jose": "^5.10.0",
    "jsonwebtoken": "^9.0.0",
    "jwks-rsa": "^3.1.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.0",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "prisma": "^5.14.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/__tests__"
    ],
    "setupFiles": [
      "<rootDir>/__tests__/setup.ts"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "testTimeout": 15000,
    "forceExit": true,
    "moduleNameMapper": {
      "^@shared/(.*)$": "<rootDir>/../../packages/shared-types/src/$1",
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "coverageThreshold": {
      "global": {
        "lines": 85
      }
    }
  }
}
