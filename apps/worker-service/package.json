{
  "name": "@card-platform/worker-service",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "lint": "echo \"No linter configured yet\" && exit 0"
  },
  "dependencies": {
    "@card-platform/shared-types": "*",
    "@prisma/client": "^5.14.0",
    "bullmq": "^5.7.0",
    "express": "^4.19.0",
    "ioredis": "^5.4.0",
    "web-push": "^3.6.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.0",
    "@types/web-push": "^3.6.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/__tests__"],
    "setupFiles": ["<rootDir>/__tests__/setup.ts"],
    "testMatch": ["**/*.test.ts"],
    "moduleNameMapper": {
      "^@shared/(.*)$": "<rootDir>/../../packages/shared-types/src/$1",
      "^@/(.*)$": "<rootDir>/src/$1",
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.ts$": ["ts-jest", {
        "tsconfig": {
          "module": "CommonJS",
          "moduleResolution": "Node"
        }
      }]
    },
    "coverageThreshold": {
      "global": {
        "lines": 85
      }
    }
  }
}
